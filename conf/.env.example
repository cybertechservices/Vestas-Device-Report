# WPP-CONF credentials for Device-Reports.ps1
# ---------------------------------------------
# Copy this file to ".env" in the same folder and fill in real values.
#   PowerShell:  Copy-Item conf\.env.example conf\.env
# The .env file is git-ignored and must NEVER be committed or copied between
# machines — each operator supplies their own credentials.
#
# Syntax: KEY=VALUE  (optional surrounding quotes; lines starting with # ignored)

WPP_USERNAME=your-username-here
WPP_PASSWORD=your-password-here
